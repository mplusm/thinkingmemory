[Unit]
Description=ThinkingMemory API Service
After=network.target

[Service]
User=root
WorkingDirectory=/root/thinkingmemory
Environment="PATH=/root/thinkingmemory/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ExecStart=/root/thinkingmemory/venv/bin/uvicorn src.api.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target