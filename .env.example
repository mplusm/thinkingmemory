# Example environment file for ThinkingMemory
# Copy this to .env and update the values

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL connection URL
DATABASE_URL=postgresql://memory_user:your_password@localhost:5432/thinkingmemory

# =============================================================================
# Redis Configuration
# =============================================================================

# Redis connection URL for working memory
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Embedding Configuration
# =============================================================================

# Server-side embedding provider:
#   local  - fastembed + BAAI/bge-small-en-v1.5 (384-dim, CPU, offline, no key)
#   openai - text-embedding-3-small (1536-dim, requires OPENAI_API_KEY)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# OPENAI_API_KEY=

# Embedding vector dimension. MUST match the provider/model above
# (384 for bge-small, 1536 for text-embedding-3-small).
EMBEDDING_DIM=384

# =============================================================================
# Application Settings
# =============================================================================

# Application name (shown in API docs)
APP_NAME=ThinkingMemory API

# Application version
APP_VERSION=0.1.0

# Debug mode (enables SQL query logging)
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Append-only audit logging of memory operations
AUDIT_ENABLED=true

# Per-tenant Postgres Row-Level Security (defense-in-depth tenant isolation).
# When true, run scripts/enable_rls.py once so the DB enforces the policy.
RLS_ENABLED=false

# =============================================================================
# MCP Server (optional)
# =============================================================================

# Default tenant id used by the MCP server when a tool call omits tenant_id.
# Leave unset for single-tenant deployments.
# THINKINGMEMORY_TENANT_ID=
