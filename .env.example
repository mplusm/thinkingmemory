# Example environment file for ThinkingMemory
# Copy this to .env and update the values

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL connection URL
DATABASE_URL=postgresql://memory_user:your_password@localhost:5432/thinkingmemory

# =============================================================================
# Redis Configuration
# =============================================================================

# Redis connection URL for working memory
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Embedding Configuration
# =============================================================================

# Dimension of stored embedding vectors. MUST match your embedding model
# (e.g. 1536 for OpenAI text-embedding-3-small, 3072 for text-embedding-3-large).
# Changing this requires recreating tables or running scripts/migrate_vector_dims.py.
EMBEDDING_DIM=1536

# =============================================================================
# Application Settings
# =============================================================================

# Application name (shown in API docs)
APP_NAME=ThinkingMemory API

# Application version
APP_VERSION=0.1.0

# Debug mode (enables SQL query logging)
DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# MCP Server (optional)
# =============================================================================

# Default tenant id used by the MCP server when a tool call omits tenant_id.
# Leave unset for single-tenant deployments.
# THINKINGMEMORY_TENANT_ID=
